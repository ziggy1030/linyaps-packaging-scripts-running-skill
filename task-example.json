{
  "global": {
    "projects_root": "/path/to/adapted/projects",
    "output_dir": "./output",
    "build_tmp_dir": "./build_cache",
    "src_dir": "./src"
  },
  "version_extract_examples": [
    {
      "description": "Firefox tar.xz release",
      "url_pattern": "firefox-{version}.en-US.linux-{arch}.tar.xz",
      "extract_regex": "firefox-([0-9]+\\.[0-9]+(?:\\.[0-9]+)*)\\.en-US"
    },
    {
      "description": "VS Code .deb package",
      "url_pattern": "code_{version}_{arch}.deb",
      "extract_regex": "code_([0-9]+\\.[0-9]+(?:\\.[0-9]+)*)_(?:amd64|arm64)\\.deb"
    },
    {
      "description": "Opera .deb package",
      "url_pattern": "opera-stable_{version}_{arch}.deb",
      "extract_regex": "opera-stable_([0-9]+\\.[0-9]+\\.[0-9]+\\.[0-9]+)_(?:amd64|arm64)\\.deb"
    }
  ],
  "tasks": [
    {
      "pkgName": "com.opera.browser",
      "src_url": "https://download3.operacdn.com/pub/opera/desktop/130.0.5847.92/linux/opera-stable_130.0.5847.92_amd64.deb",
      "arch": "x86_64",
      "orig_version": "130.0.5847.92"
    },
    {
      "pkgName": "com.visualstudio.code",
      "src_url": "https://update.code.visualstudio.com/latest/linux-deb-x64/stable",
      "arch": "x86_64",
      "orig_version": ""
    }
  ]
}
